# Hermes Agent Environment Configuration for Railway
# Copy to .env and fill in values for each agent

# =============================================================================
# LLM CONFIGURATION
# =============================================================================
# Using Ollama Cloud (qwen3.5:cloud)
OLLAMA_API_KEY=your_ollama_api_key_here

# =============================================================================
# TELEGRAM CONFIGURATION (Webhook Mode for Railway)
# =============================================================================
# Bot token (unique per agent)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Webhook URL (Railway provides this automatically)
# Format: https://<your-service>.railway.app/telegram
TELEGRAM_WEBHOOK_URL=https://your-agent.railway.app/telegram
TELEGRAM_WEBHOOK_PORT=8080

# Allowed users and chats
TELEGRAM_ALLOWED_USERS=8502906149
TELEGRAM_ALLOWED_CHATS=-1003936982744
TELEGRAM_HOME_CHANNEL=-1003936982744

# =============================================================================
# GATEWAY CONFIGURATION
# =============================================================================
# Enable webhook mode (required for Railway)
# When TELEGRAM_WEBHOOK_URL is set, gateway uses webhook instead of polling

# =============================================================================
# OPTIONAL: Other Tool API Keys
# =============================================================================
# GitHub (for code operations)
# GITHUB_TOKEN=ghp_...

# Twitter/X (for social media operations)
# XURL_API_KEY=...
# XURL_API_SECRET=...

# Exa (web search)
# EXA_API_KEY=...
